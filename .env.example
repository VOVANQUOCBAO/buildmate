# ---------------------------------------------------------------------------
# BuildMate ASG environment
#
# Every value is OPTIONAL. With none set, the app runs in "mock mode":
#   - data comes from data/*.json fixtures
#   - the builder profile is stored in localStorage
#   - AI explanations use a deterministic template
# Fill these in to switch on real auth, a real database, and real Claude AI.
# Copy this file to `.env.local` and restart `npm run dev`.
# ---------------------------------------------------------------------------

# --- Supabase (auth + Postgres + per-user data) ----------------------------
# Project Settings -> API in the Supabase dashboard.
# Leaving these blank keeps the app in mock mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public site origin, used to build OAuth / magic-link redirect URLs.
# Local dev: http://localhost:3000  |  Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic Claude (grounded AI explanation layer) ----------------------
# https://console.anthropic.com/ -> API Keys.
# Leaving this blank uses the deterministic fallback explanation.
ANTHROPIC_API_KEY=
# Optional model override (defaults to a current Claude model in code).
ANTHROPIC_MODEL=
